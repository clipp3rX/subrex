cleanup_empty_files() {
    local removed=0
    for f in *.txt; do
        [[ -f "$f" ]] || continue
        if [[ ! -s "$f" ]]; then
            rm -f "$f"
            print_info "Removed empty file → ${DIM}${f}${RESET}"
            removed=$(( removed + 1 ))
        fi
    done
    if (( removed == 0 )); then
        print_success "No empty files found"
    else
        print_success "Cleanup done → ${removed} empty file(s) removed"
    fi
}

